	<!-- Test Case 1: Get Customers - Success Scenario -->
	<munit:test name="get-customers-success-test" description="Test successful customer retrieval">
		
		<munit:execution>
			<http:request method="GET" doc:name="GET /api/customers" 
				path="/api/customers" 
				config-ref="HTTP_Request_configuration">
				<http:query-params>
					<http:query-param paramName="status" value="ACTIVE"/>
				</http:query-params>
			</http:request>
		</munit:execution>
		
		<munit:validation>
			<munit-tools:assert-that expression="#[attributes.statusCode]" is="#[MunitTools::equalTo(200)]"/>
			<munit-tools:assert-that expression="#[payload.customers]" is="#[MunitTools::hasSize(2)]"/>
			<munit-tools:assert-that expression="#[payload.customers[0].name]" is="#[MunitTools::equalTo('John Doe')]"/>
			<munit-tools:assert-that expression="#[payload.metadata.version]" is="#[MunitTools::equalTo('4.9')]"/>
			<munit-tools:assert-that expression="#[payload.metadata.totalRecords]" is="#[MunitTools::equalTo(2)]"/>
		</munit:validation>
	</munit:test>

